{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testdatafactory.dev/schemas/tdf-contract.schema.json",
  "title": "TestData Factory Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "source",
    "locale",
    "fields",
    "scenarios",
    "generation",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "locale": {
      "$ref": "#/$defs/locale"
    },
    "fields": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/field"
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "generation": {
      "$ref": "#/$defs/generation"
    },
    "validation": {
      "$ref": "#/$defs/validation"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["url", "openapi", "json_schema", "page_object", "manual"]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language"],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16
        },
        "country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 2
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataType", "businessType", "required"],
      "properties": {
        "selector": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "dataType": {
          "type": "string",
          "enum": ["string", "integer", "decimal", "boolean", "date", "datetime", "time", "enum", "array", "object"]
        },
        "businessType": {
          "type": "string",
          "enum": [
            "first_name",
            "last_name",
            "full_name",
            "username",
            "email",
            "password",
            "phone_number",
            "country_code",
            "address_line",
            "city",
            "state",
            "postal_code",
            "country",
            "date",
            "date_of_birth",
            "time",
            "datetime",
            "amount",
            "currency",
            "percentage",
            "quantity",
            "integer",
            "decimal",
            "boolean",
            "enum",
            "url",
            "domain",
            "uuid",
            "national_id",
            "passport_number",
            "tax_id",
            "account_number",
            "iban",
            "credit_card_number",
            "cvv",
            "expiry_date",
            "otp",
            "free_text"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "minLength": {
              "type": "integer",
              "minimum": 0
            },
            "maxLength": {
              "type": "integer",
              "minimum": 0
            },
            "minimum": {
              "type": "number"
            },
            "maximum": {
              "type": "number"
            },
            "pattern": {
              "type": "string"
            },
            "format": {
              "type": "string"
            },
            "country": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "values": {
              "type": "array",
              "items": {
                "type": ["string", "number", "boolean"]
              }
            },
            "unique": {
              "type": "boolean"
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "matchesField": {
              "type": "string",
              "minLength": 1
            },
            "rangeStartFor": {
              "type": "string",
              "minLength": 1
            },
            "rangeEndFor": {
              "type": "string",
              "minLength": 1
            },
            "minFor": {
              "type": "string",
              "minLength": 1
            },
            "maxFor": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "inference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["confidence", "signals"],
          "properties": {
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "signals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "description", "fields"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$"
        },
        "kind": {
          "type": "string",
          "enum": ["positive", "negative", "boundary", "security"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["strategy"],
            "properties": {
              "strategy": {
                "type": "string",
                "minLength": 1
              },
              "value": true
            }
          }
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic", "defaultSeed"],
      "properties": {
        "deterministic": {
          "type": "boolean"
        },
        "defaultSeed": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "lastValidatedBy": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["valid", "needs_review", "invalid"]
        }
      }
    }
  }
}
