{
  "openapi": "3.1.0",
  "info": {
    "title": "TestData Factory API",
    "version": "1.0.0",
    "description": "Self-hosted API for contract validation and deterministic test data generation."
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "API is healthy"
          }
        }
      }
    },
    "/v1/model-profiles": {
      "get": {
        "summary": "List local model profiles",
        "responses": {
          "200": {
            "description": "Supported model profiles"
          }
        }
      }
    },
    "/v1/contracts/validate": {
      "post": {
        "summary": "Validate a contract",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContractPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Structured contract validation feedback",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/data/generate": {
      "post": {
        "summary": "Generate deterministic test data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated test data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Structured validation feedback",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ai/scenarios": {
      "post": {
        "summary": "Draft scenario additions with local AI validation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AIScenarioAssistPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI scenario proposal and structured validation feedback",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIScenarioAssistResponse"
                }
              }
            }
          },
          "422": {
            "description": "Structured validation feedback",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          },
          "502": {
            "description": "Local model provider failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationResult"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AIScenarioAssistPayload": {
        "type": "object",
        "required": ["contract", "provider"],
        "properties": {
          "contract": {
            "type": "object",
            "additionalProperties": true
          },
          "provider": {
            "type": "object",
            "additionalProperties": true
          },
          "modelProfile": {
            "type": "string",
            "default": "balanced"
          },
          "goal": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "AIScenarioAssistResponse": {
        "type": "object",
        "required": ["mode", "modelProfile", "provider", "proposal", "validation"],
        "properties": {
          "mode": {
            "type": "string"
          },
          "modelProfile": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/AIProviderMetadata"
          },
          "proposal": {
            "type": "object",
            "additionalProperties": true
          },
          "validation": {
            "$ref": "#/components/schemas/ValidationResult"
          }
        }
      },
      "AIProviderMetadata": {
        "type": "object",
        "required": ["type", "model"],
        "properties": {
          "type": {
            "type": "string"
          },
          "model": {
            "type": "string"
          }
        }
      },
      "ContractPayload": {
        "type": "object",
        "required": ["contract"],
        "properties": {
          "contract": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "GeneratePayload": {
        "type": "object",
        "required": ["contract", "scenarioId"],
        "properties": {
          "contract": {
            "type": "object",
            "additionalProperties": true
          },
          "scenarioId": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "seed": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "GenerateResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "ValidationFinding": {
        "type": "object",
        "required": ["severity", "field", "message", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          },
          "field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "message": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        }
      },
      "ValidationResult": {
        "type": "object",
        "required": ["status", "score", "findings"],
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "type": "string",
            "enum": ["valid", "needs_review", "invalid"]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "findings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationFinding"
            }
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["loc", "msg", "type"],
        "properties": {
          "loc": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            }
          },
          "msg": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "ctx": {
            "type": "object"
          },
          "input": {}
        }
      }
    }
  }
}
