      "kind": "negative",
      "description": "Confirmation fields intentionally differ from their source fields.",
      "fields": {
        "confirmPassword": {
          "strategy": "mismatch_field"
        }
      }
    },
    {
      "id": "invalid_date_ranges",
      "kind": "negative",
      "description": "Date range end fields occur before their start fields.",
      "fields": {
        "endDate": {
          "strategy": "date_before_related_field"
        }
      }
    },
    {
      "id": "invalid_numeric_ranges",
      "kind": "negative",
      "description": "Numeric maximum fields are below their minimum fields.",
      "fields": {
