        }
      }
    },
    {
      "id": "empty_string_fields",
      "kind": "negative",
      "description": "String-like fields are submitted as empty strings.",
      "fields": {
        "notes": {
          "strategy": "empty_string"
        }
      }
    },
    {
      "id": "whitespace_only_fields",
      "kind": "negative",
      "description": "String-like fields contain only whitespace.",
      "fields": {
        "notes": {
          "strategy": "whitespace_only"
        }
      }
    },
    {
      "id": "over_max_length_fields",
      "kind": "negative",
      "description": "String fields are one character over their maximum length.",
      "fields": {
        "notes": {
          "strategy": "over_max_length"
        }
      }
    },
    {
      "id": "below_min_length_fields",
      "kind": "negative",
      "description": "String fields are one character below their minimum length.",
      "fields": {
        "notes": {
          "strategy": "below_min_length"
        }
      }
    },
    {
      "id": "duplicate_unique_fields",
      "kind": "negative",
      "description": "Fields marked unique use duplicate values across generated records.",
      "fields": {
        "email": {
          "strategy": "duplicate_value"
        }
      }
