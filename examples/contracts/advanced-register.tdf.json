  "scenarios": [
    {
      "id": "valid_advanced_signup",
      "kind": "positive",
      "description": "Advanced signup fields contain valid values and cross-field dependencies are satisfied.",
      "fields": {
        "email": {
          "strategy": "valid_email"
        },
        "password": {
          "strategy": "valid_password"
        },
        "confirmPassword": {
          "strategy": "match_field"
        },
        "startDate": {
          "strategy": "valid_date"
        },
        "endDate": {
          "strategy": "range_end_after_start"
        },
        "minGuests": {
          "strategy": "valid_integer"
        },
        "maxGuests": {
          "strategy": "numeric_max_at_or_above_min"
        },
        "notes": {
          "strategy": "valid_free_text"
        },
        "marketingOptIn": {
          "strategy": "valid_boolean"
        }
      }
    },
    {
      "id": "xss_payloads",
      "kind": "security",
      "description": "Text-like fields contain a common reflected XSS probe.",
