        }
      }
    },
    {
      "id": "sql_injection_payloads",
      "kind": "security",
      "description": "Text-like fields contain a common SQL injection probe.",
      "fields": {
        "notes": {
          "strategy": "sql_injection_payload"
        }
      }
    },
    {
