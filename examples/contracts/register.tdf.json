{
  "schemaVersion": "1.0",
  "id": "register",
  "source": {
    "type": "manual",
    "value": "examples/register"
  },
  "locale": {
    "country": "US",
    "language": "en"
  },
  "fields": {
    "firstName": {
      "selector": "#first-name",
      "label": "First name",
      "dataType": "string",
      "businessType": "first_name",
      "required": true,
      "constraints": {
        "minLength": 1,
        "maxLength": 80
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "email": {
      "selector": "#email",
      "label": "Email",
      "dataType": "string",
      "businessType": "email",
      "required": true,
      "constraints": {
        "format": "email"
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "phone": {
      "selector": "#phone",
      "label": "Phone",
      "dataType": "string",
      "businessType": "phone_number",
      "required": true,
      "constraints": {
        "country": "US",
        "minLength": 10,
        "maxLength": 16
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "password": {
      "selector": "#password",
      "label": "Password",
      "dataType": "string",
      "businessType": "password",
      "required": true,
      "constraints": {
        "minLength": 8,
        "maxLength": 64
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "age": {
      "selector": "#age",
      "label": "Age",
      "dataType": "integer",
      "businessType": "integer",
      "required": true,
      "constraints": {
        "minimum": 18,
        "maximum": 99
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "plan": {
      "selector": "#plan",
      "label": "Plan",
      "dataType": "enum",
      "businessType": "enum",
      "required": true,
      "constraints": {
        "values": ["basic", "pro", "enterprise"]
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "birthDate": {
      "selector": "#birth-date",
      "label": "Birth date",
      "dataType": "date",
      "businessType": "date_of_birth",
      "required": false,
      "constraints": {
        "format": "date"
      },
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    },
    "newsletter": {
      "selector": "#newsletter",
      "label": "Newsletter",
      "dataType": "boolean",
      "businessType": "boolean",
      "required": false,
      "inference": {
        "confidence": 1,
        "signals": ["manual"]
      }
    }
  },
  "scenarios": [
    {
      "id": "valid_signup",
      "kind": "positive",
      "description": "All required signup fields contain valid values.",
      "fields": {
        "firstName": {
          "strategy": "valid_first_name"
        },
        "email": {
          "strategy": "valid_email"
        },
        "phone": {
          "strategy": "valid_phone"
        },
        "password": {
          "strategy": "valid_password"
        },
        "age": {
          "strategy": "valid_integer"
        },
        "plan": {
          "strategy": "valid_enum"
        },
        "birthDate": {
          "strategy": "valid_date"
        },
        "newsletter": {
          "strategy": "valid_boolean"
        }
      }
    },
    {
      "id": "invalid_email_format",
      "kind": "negative",
      "description": "Email field contains a value that is not a valid email address.",
      "fields": {
        "email": {
          "strategy": "invalid_email_format"
        }
      }
    }
  ],
  "generation": {
    "deterministic": true,
    "defaultSeed": "register-suite"
  },
  "validation": {
    "lastValidatedBy": "manual",
    "status": "valid"
  }
}
